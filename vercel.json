{
  "buildCommand": "node scripts/patch-vercel-demo-hosts.mjs && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "michal-demo.vercel.app"
        }
      ],
      "destination": "/api/share/michal?to=/book"
    },
    {
      "source": "/share/:client",
      "destination": "/api/share/:client"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
