{
  "buildCommand": "node scripts/patch-vercel-demo-hosts.mjs && node scripts/generate-demo-landing-pages.mjs && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "michal-demo.vercel.app"
        }
      ],
      "destination": "/api/share/michal"
    },
    {
      "source": "/share/:client",
      "destination": "/api/share/:client"
    },
    {
      "source": "/((?!api|assets|landing-).*)",
      "destination": "/index.html"
    }
  ]
}
