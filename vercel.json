{
  "buildCommand": "node scripts/patch-vercel-demo-hosts.mjs && node scripts/generate-demo-landing-pages.mjs && npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "michal-demo.vercel.app"
        }
      ],
      "dest": "/api/share/michal"
    },
    {
      "src": "/m",
      "has": [
        {
          "type": "host",
          "value": "michal-demo.vercel.app"
        }
      ],
      "dest": "/api/share/michal"
    },
    {
      "src": "/share/(.*)",
      "dest": "/api/share/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
