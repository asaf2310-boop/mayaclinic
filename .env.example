VITE_SUPABASE_URL=https://furrjspvtmyvjikynkfj.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Maya / ofirbaby Vercel projects (optional — defaults to clinicSite.id "maya")
# VITE_CLINIC_TENANT_ID=maya

# Demo environment only: fake data in browser localStorage, no Supabase.
# Use this in a separate Vercel demo project instead of VITE_SUPABASE_*.
# VITE_DEMO_MODE=true
# לקוחות דמו נוספים: ערוך demo-clients.json (לא משתנה env)
# DEMO_PRIMARY_ORIGIN=https://karinshinanit-demo.vercel.app

# Base44 fallback only. Supabase is used when both VITE_SUPABASE_* values are set.
VITE_BASE44_APP_ID=69ff3dea5e105013fde56ce0
VITE_BASE44_APP_BASE_URL=

# Email (Vercel server only — do NOT prefix with VITE_)
GMAIL_USER=maya@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
MAYA_CLINIC_NAME=הקליניקה של מאיה
CRON_SECRET=random_long_secret_for_reminders_cron

# Server-side Supabase (for reminder cron; can reuse anon key or use service role)
SUPABASE_URL=https://furrjspvtmyvjikynkfj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_optional

